# Workbench — environment configuration
# Copy to .env and fill in required values.
# All variables use the WORKBENCH_ prefix.

# --- Workspace ---
# Absolute path to the workspace root containing git repos (required in production).
WORKBENCH_WORKSPACE_ROOT=/path/to/workspace

# Directory containing reference docs for the 'reference' context type.
# Defaults to <workspace_root>/work-directory/references
# WORKBENCH_REFERENCES_DIR=

# --- OpenCode ---
# Path to the opencode binary.
WORKBENCH_OPENCODE_BIN=opencode

# Override the default model for opencode run. Leave empty to use opencode's default.
# WORKBENCH_OPENCODE_MODEL=

# --- Workers ---
# Maximum number of concurrent task workers.
WORKBENCH_MAX_WORKERS=4

# Per-task timeout in seconds (default 30 minutes).
WORKBENCH_TASK_TIMEOUT=1800

# --- Git ---
# Prefix for auto-created branches, e.g. agent/task-abc123.
WORKBENCH_BRANCH_PREFIX=agent

# Default base branch for PRs.
WORKBENCH_DEFAULT_BASE_BRANCH=main

# --- API ---
WORKBENCH_HOST=127.0.0.1
WORKBENCH_PORT=8420

# --- Database ---
# Async SQLAlchemy connection string. Matches docker-compose.yml defaults.
WORKBENCH_DATABASE_URL=postgresql+asyncpg://workbench:workbench_dev@localhost:5433/workbench

# --- External services ---
# Jira integration (optional — used for Jira task resolution and sync).
# WORKBENCH_JIRA_BASE_URL=https://your-org.atlassian.net
# WORKBENCH_JIRA_API_TOKEN=
# WORKBENCH_JIRA_USER_EMAIL=

# GitHub token (optional — falls back to `gh` CLI auth).
# WORKBENCH_GITHUB_TOKEN=
